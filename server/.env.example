# Copy to .env and fill in as needed. All of these are optional — the app runs
# with sensible defaults (no real email, nightly digest at 7am) if omitted.

# SMTP (server/utils/mailer.js). If SMTP_HOST is unset, emails are logged to
# the console instead of sent — no credentials needed for local dev.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="ChronosPM <no-reply@chronospm.local>"

# Cron schedule for the nightly digest job (server/cron.js), in standard
# 5-field cron syntax. Default: 7am every day.
CRON_SCHEDULE="0 7 * * *"

# Used to build the link in password-reset emails (server/routes/auth.js).
# Defaults to the Vite dev server's origin.
CLIENT_ORIGIN=http://localhost:5173

# Express server port (server/index.js).
PORT=3001
