{
  "name": "chronospm-multi-project",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "seed": "npm run seed -w server",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "workspaces": [
    "server",
    "client"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "concurrently": "^9.1.0"
  }
}
